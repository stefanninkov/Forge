rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /projects/{projectId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;

      match /{sub=**} {
        allow read, write: if isAuth();
      }
    }

    match /templates/{templateId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        resource == null || resource.data.userId == request.auth.uid
      );
      allow create: if isAuth();
    }

    match /animationPresets/{presetId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        resource == null || resource.data.userId == request.auth.uid || resource.data.isSystem == true
      );
      allow create: if isAuth();
    }

    match /setupProfiles/{profileId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /figmaAnalyses/{analysisId} {
      allow read, write: if isAuth();
    }

    match /favorites/{favoriteId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /capturedSections/{sectionId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }

    match /sectionFolders/{folderId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }
  }
}
