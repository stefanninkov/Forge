generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  name         String?
  avatarUrl    String?  @map("avatar_url")
  plan         Plan     @default(FREE)
  preferences  Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects               Project[]
  setupProfiles          SetupProfile[]
  integrations           UserIntegration[]
  favorites              Favorite[]
  activityLogs           ActivityLog[]
  capturedSections       CapturedSection[]
  sectionFolders         SectionFolder[]
  scalingConfigs         ScalingConfig[]
  notificationPreferences NotificationPreference[]
  handoffReports         HandoffReport[]

  @@map("users")
}

model Project {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  description     String?
  notes           String?  @db.Text
  webflowSiteId   String?  @map("webflow_site_id")
  figmaFileKey    String?  @map("figma_file_key")
  setupProfileId  String?  @map("setup_profile_id") @db.Uuid
  animationConfig Json?    @map("animation_config")
  scriptStatus    ScriptStatus @default(NOT_DEPLOYED) @map("script_status")
  scriptConfig    Json?    @map("script_config")
  lastDeployedAt  DateTime? @map("last_deployed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  setupProfile     SetupProfile?     @relation(fields: [setupProfileId], references: [id])
  setupProgress    SetupProgress[]
  figmaAnalyses    FigmaAnalysis[]
  audits           Audit[]
  auditAlerts      AuditAlert[]
  favorites        Favorite[]
  activityLogs     ActivityLog[]
  capturedSections CapturedSection[]
  scalingConfigs   ScalingConfig[]
  handoffReports   HandoffReport[]

  @@map("projects")
}

model SetupProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  checklistConfig Json     @map("checklist_config")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@map("setup_profiles")
}

model SetupProgress {
  id          String      @id @default(uuid()) @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  itemKey     String      @map("item_key")
  status      SetupStatus @default(PENDING)
  completedAt DateTime?   @map("completed_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, itemKey])
  @@map("setup_progress")
}

model AnimationPreset {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  name        String
  description String?
  category    String
  engine      AnimationEngine
  trigger     AnimationTrigger
  config      Json
  previewHtml String?  @map("preview_html") @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  isPublished Boolean  @default(false) @map("is_published")
  tags        String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([engine])
  @@index([trigger])
  @@index([isSystem])
  @@map("animation_presets")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model UserIntegration {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  provider     String
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_integrations")
}

model Template {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  name            String
  description     String?
  category        String
  type            TemplateType @default(SKELETON)
  isPreset        Boolean  @default(false) @map("is_preset")
  structure       Json
  styles          Json?
  animationAttrs  Json?    @map("animation_attrs")
  tags            String[] @default([])
  sourceProjectId String?  @map("source_project_id") @db.Uuid
  isPublished     Boolean  @default(false) @map("is_published")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([category])
  @@index([isPreset])
  @@map("templates")
}

model FigmaAnalysis {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  figmaFileKey    String    @map("figma_file_key")
  figmaPageName   String?   @map("figma_page_name")
  rawStructure    Json?     @map("raw_structure")
  auditResults    Json?     @map("audit_results")
  aiSuggestions   Json?     @map("ai_suggestions")
  finalStructure  Json?     @map("final_structure")
  pushedToWebflow Boolean   @default(false) @map("pushed_to_webflow")
  pushedAt        DateTime? @map("pushed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("figma_analyses")
}

enum Plan {
  FREE
  PRO
  AGENCY

  @@map("plan")
}

enum SetupStatus {
  PENDING
  COMPLETED
  SKIPPED

  @@map("setup_status")
}

enum TemplateType {
  SKELETON
  STYLED

  @@map("template_type")
}

model Audit {
  id         String    @id @default(uuid()) @db.Uuid
  projectId  String    @map("project_id") @db.Uuid
  type       AuditType
  urlAudited String    @map("url_audited")
  results    Json
  score      Float
  createdAt  DateTime  @default(now()) @map("created_at")

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  alerts  AuditAlert[]

  @@index([projectId])
  @@index([type])
  @@map("audits")
}

model AuditAlert {
  id        String        @id @default(uuid()) @db.Uuid
  auditId   String        @map("audit_id") @db.Uuid
  projectId String        @map("project_id") @db.Uuid
  type      AlertType
  message   String
  severity  AlertSeverity
  read      Boolean       @default(false)
  createdAt DateTime      @default(now()) @map("created_at")

  audit   Audit   @relation(fields: [auditId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("audit_alerts")
}

enum AuditType {
  SPEED
  SEO
  AEO

  @@map("audit_type")
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL

  @@map("alert_severity")
}

enum AlertType {
  SCORE_DROP
  ISSUE_FOUND
  NEW_ERROR

  @@map("alert_type")
}

enum AnimationEngine {
  CSS
  GSAP

  @@map("animation_engine")
}

enum AnimationTrigger {
  SCROLL
  HOVER
  CLICK
  LOAD

  @@map("animation_trigger")
}

enum ScriptStatus {
  SYNCED
  OUTDATED
  NOT_DEPLOYED
  ERROR

  @@map("script_status")
}

enum ActivityAction {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
  AUDIT_RUN
  TEMPLATE_CREATED
  TEMPLATE_PUSHED
  ANIMATION_APPLIED
  SCRIPT_DEPLOYED
  SECTION_CAPTURED
  FIGMA_ANALYZED
  SETTINGS_UPDATED
  PROJECT_DUPLICATED

  @@map("activity_action")
}

// ─── Favorites ───────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  projectId  String?  @map("project_id") @db.Uuid
  templateId String?  @map("template_id") @db.Uuid
  presetId   String?  @map("preset_id") @db.Uuid
  type       String   // "project" | "template" | "preset"
  createdAt  DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, type, projectId])
  @@unique([userId, type, templateId])
  @@unique([userId, type, presetId])
  @@index([userId])
  @@map("favorites")
}

// ─── Activity Log ────────────────────────────────────────────────

model ActivityLog {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  projectId String?        @map("project_id") @db.Uuid
  action    ActivityAction
  details   Json?
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Captured Sections ───────────────────────────────────────────

model CapturedSection {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  projectId    String?  @map("project_id") @db.Uuid
  folderId     String?  @map("folder_id") @db.Uuid
  name         String
  html         String   @db.Text
  css          String   @db.Text
  attributes   Json     @default("{}")
  elementCount Int      @default(0) @map("element_count")
  thumbnail    String?  @db.Text
  capturedFrom String   @map("captured_from")
  tags         String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folder  SectionFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([folderId])
  @@map("captured_sections")
}

model SectionFolder {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  name     String
  parentId String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   SectionFolder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children SectionFolder[]   @relation("FolderHierarchy")
  sections CapturedSection[]

  @@index([userId])
  @@map("section_folders")
}

// ─── Scaling Configs ─────────────────────────────────────────────

model ScalingConfig {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String?  @map("project_id") @db.Uuid
  name      String
  config    Json     // BreakpointConfig[]
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@map("scaling_configs")
}

// ─── Notification Preferences ────────────────────────────────────

model NotificationPreference {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  channel   String   // "email" | "in_app"
  event     String   // "audit_complete" | "score_drop" | "deploy_success" etc.
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, event])
  @@map("notification_preferences")
}

// ─── Audit Schedules ────────────────────────────────────────────

model AuditSchedule {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  projectId String          @map("project_id") @db.Uuid
  type      AuditType
  url       String
  frequency ScheduleFrequency
  enabled   Boolean         @default(true)
  lastRunAt DateTime?       @map("last_run_at")
  nextRunAt DateTime?       @map("next_run_at")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([projectId, type])
  @@index([userId])
  @@index([nextRunAt])
  @@map("audit_schedules")
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY

  @@map("schedule_frequency")
}

// ─── Community Library ──────────────────────────────────────────

model CommunityTemplate {
  id            String   @id @default(uuid()) @db.Uuid
  templateId    String   @map("template_id") @db.Uuid
  authorId      String   @map("author_id") @db.Uuid
  authorName    String   @map("author_name")
  name          String
  description   String?
  category      String
  type          TemplateType @default(SKELETON)
  structure     Json
  styles        Json?
  animationAttrs Json?   @map("animation_attrs")
  tags          String[] @default([])
  downloads     Int      @default(0)
  likes         Int      @default(0)
  featured      Boolean  @default(false)
  publishedAt   DateTime @default(now()) @map("published_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([category])
  @@index([featured])
  @@index([downloads])
  @@index([publishedAt])
  @@map("community_templates")
}

model CommunityLike {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  templateId  String   @map("template_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, templateId])
  @@map("community_likes")
}

// ─── Teams ──────────────────────────────────────────────────────

model Team {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  ownerId   String   @map("owner_id") @db.Uuid
  avatarUrl String?  @map("avatar_url")
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members      TeamMember[]
  invitations  TeamInvitation[]

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model TeamInvitation {
  id        String           @id @default(uuid()) @db.Uuid
  teamId    String           @map("team_id") @db.Uuid
  email     String
  role      TeamRole         @default(MEMBER)
  token     String           @unique
  status    InvitationStatus @default(PENDING)
  invitedBy String           @map("invited_by") @db.Uuid
  expiresAt DateTime         @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
  @@map("team_invitations")
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER

  @@map("team_role")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED

  @@map("invitation_status")
}

// ─── Handoff Reports ─────────────────────────────────────────────

model HandoffReport {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  title     String
  sections  Json     // Array of report sections with content
  branding  Json?    // Logo, colors, company name
  shareToken String? @unique @map("share_token")
  isPublic  Boolean  @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([shareToken])
  @@map("handoff_reports")
}
