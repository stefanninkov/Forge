{
  "name": "forge",
  "private": true,
  "version": "0.2.0",
  "description": "Full-pipeline Webflow development accelerator",
  "workspaces": [
    "client",
    "functions"
  ],
  "scripts": {
    "dev": "npm -w client run dev",
    "dev:functions": "cd functions && npm run build:watch",
    "build": "npm -w client run build",
    "build:functions": "cd functions && npm run build",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy": "cd client && npm run build && npx gh-pages -d dist",
    "deploy:all": "firebase deploy",
    "emulate": "firebase emulators:start"
  }
}
